---
interface Course {
  course_name: string;
  course_code: string;
  instructor: string;
  day_of_week: string;
  period: number;
  semester: string;
  credits: number;
  detail_url: string;
  priority: string;
  recommended_year: number;
  max_recommended_year: number;
}

interface Props {
  courses: Course[];
}

const { courses } = Astro.props;

const intensiveCourses = courses.filter(
  course => course.period === 0 || course.semester === "集中"
);

function priorityBorderClass(priority: string): string {
  switch (priority) {
    case "A": return "border-l-red-500 bg-red-50";
    case "B": return "border-l-blue-500 bg-blue-50";
    case "C": return "border-l-green-500 bg-green-50";
    default: return "border-l-gray-400 bg-gray-50";
  }
}

function priorityBadgeClasses(priority: string): string {
  switch (priority) {
    case "A": return "bg-red-500 text-white";
    case "B": return "bg-blue-500 text-white";
    case "C": return "bg-green-500 text-white";
    default: return "bg-gray-400 text-white";
  }
}

function priorityLabel(priority: string): string {
  switch (priority) {
    case "A": return "必修";
    case "B": return "選択必修";
    case "C": return "推奨";
    default: return "";
  }
}
---

{intensiveCourses.length > 0 && (
  <section class="mt-8">
    <h2 class="text-lg font-bold text-gray-900 mb-3">集中講義</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {intensiveCourses.map(course => (
        <a
          href={course.detail_url}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            "course-cell block rounded-lg border border-l-4 p-3 transition-colors hover:shadow-md cursor-pointer no-underline",
            priorityBorderClass(course.priority),
          ]}
          data-recommended-year={course.recommended_year}
          data-max-recommended-year={course.max_recommended_year}
        >
          <div class="flex items-start justify-between gap-2">
            <span class="font-medium text-gray-900">{course.course_name}</span>
            <span class:list={[
              "shrink-0 text-xs px-1.5 py-0.5 rounded font-medium",
              priorityBadgeClasses(course.priority),
            ]}>
              {priorityLabel(course.priority)}
            </span>
          </div>
          <div class="text-sm text-gray-600 mt-1">{course.instructor}</div>
          <div class="text-xs text-gray-400 mt-1">{course.credits}単位 / {course.semester}</div>
        </a>
      ))}
    </div>
  </section>
)}
